# N8N Configuration
N8N_HOST=your-n8n-instance.com
N8N_PORT=5678
N8N_PROTOCOL=https

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_BOT_USERNAME=yourstorebot
TELEGRAM_BOT_NAME=Your Store Assistant
TELEGRAM_CHAT_ID=123456789

# Mistral AI Configuration
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-tiny
MISTRAL_MAX_TOKENS=500
MISTRAL_TEMPERATURE=0.7

# Google Sheets Configuration
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_SHEET_NAME=Sheet1
GOOGLE_SHEETS_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_SHEETS_CLIENT_SECRET=your_client_secret

# Store Configuration
STORE_NAME=Your Store Name
STORE_LANGUAGE=en
STORE_CURRENCY=USD
STORE_TIMEZONE=UTC

# AI Agent Configuration
AI_AGENT_MEMORY_WINDOW=10
AI_AGENT_MAX_ITERATIONS=5
AI_AGENT_VERBOSE=false

# Monitoring (Optional)
LOG_LEVEL=info
ENABLE_ANALYTICS=true
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
